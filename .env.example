# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is listed in .gitignore.

# ------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-key-here

GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.1

GEMINI_API_KEY=your-gemini-key-here

# ------------------------------------------------------------
# Database
#
# DOCKER (docker compose up):
#   Use 'db' as the hostname — this is the Postgres service name
#   in docker-compose.yml. The compose file overrides these two
#   vars automatically, but set them here as your default.
#
# LOCAL (running app directly on host, outside Docker):
#   Change 'db' to 'localhost'.
# ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://dev_user:root123@db:5432/ecommerce
READ_DATABASE_URL=postgresql+psycopg://analyst_bot:root123@db:5432/ecommerce

# ------------------------------------------------------------
# LangSmith (observability / tracing)
# ------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key-here
LANGSMITH_PROJECT=Ecommerce RAG

# ------------------------------------------------------------
# E2B (code execution sandbox)
# ------------------------------------------------------------
E2B_API_KEY=e2b_your-e2b-key-here


#  To run:
#   docker compose up --build

#   One thing to note: if your existing PostgreSQL data (schema + seed) lives outside Docker, comment out the db service in docker-compose.yml, remove the depends_on block from app, and set
#   DATABASE_URL/READ_DATABASE_URL in .env to point at your external host using localhost (or your host's IP if on Linux — not db).